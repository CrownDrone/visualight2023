    `kcu`.`CONSTRAINT_NAME` AS `constraint_name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `referenced_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `referenced_column_name`
FROM `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`
JOIN `information_schema`.`KEY_COLUMN_USAGE` AS `kcu` ON
    (
        `kcu`.`CONSTRAINT_CATALOG` = `rc`.`CONSTRAINT_CATALOG` OR
        (`kcu`.`CONSTRAINT_CATALOG` IS NULL AND `rc`.`CONSTRAINT_CATALOG` IS NULL)
    ) AND
    `kcu`.`CONSTRAINT_SCHEMA` = `rc`.`CONSTRAINT_SCHEMA` AND
    `kcu`.`CONSTRAINT_NAME` = `rc`.`CONSTRAINT_NAME`
WHERE `rc`.`CONSTRAINT_SCHEMA` = database() AND `kcu`.`TABLE_SCHEMA` = database()
AND `rc`.`TABLE_NAME` = 'user' AND `kcu`.`TABLE_NAME` = 'user'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1702123457.50323;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"C:\xampp\htdocs\visualight\common\models\User.php";s:4:"line";i:366;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5403752;}i:13;a:6:{i:0;s:61:"SELECT * FROM `user` WHERE (`id`=1) AND (`status` IN (10, 5))";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1702123457.514131;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"C:\xampp\htdocs\visualight\common\models\User.php";s:4:"line";i:366;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5876872;}i:16;a:6:{i:0;s:44:"Bootstrap with yii\debug\Module::bootstrap()";i:1;i:8;i:2;s:31:"yii\base\Application::bootstrap";i:3;d:1702123457.52737;i:4;a:0:{}i:5;i:6625760;}i:17;a:6:{i:0;s:19:"Loading module: gii";i:1;i:8;i:2;s:26:"yii\base\Module::getModule";i:3;d:1702123457.53047;i:4;a:0:{}i:5;i:6847664;}i:18;a:6:{i:0;s:42:"Bootstrap with yii\gii\Module::bootstrap()";i:1;i:8;i:2;s:31:"yii\base\Application::bootstrap";i:3;d:1702123457.530975;i:4;a:0:{}i:5;i:6872496;}i:41;a:6:{i:0;s:30:"Route requested: 'site/yearly'";i:1;i:8;i:2;s:34:"yii\web\Application::handleRequest";i:3;d:1702123457.531749;i:4;a:0:{}i:5;i:6926456;}i:42;a:6:{i:0;s:25:"Route to run: site/yearly";i:1;i:8;i:2;s:30:"yii\base\Controller::runAction";i:3;d:1702123457.535632;i:4;a:0:{}i:5;i:7402792;}i:43;a:6:{i:0;s:66:"Running action: backend\controllers\SiteController::actionYearly()";i:1;i:8;i:2;s:36:"yii\base\InlineAction::runWithParams";i:3;d:1702123457.536185;i:4;a:0:{}i:5;i:7424208;}i:44;a:6:{i:0;s:66:"Opening DB connection: mysql:host=localhost;dbname=visualight2data";i:1;i:4;i:2;s:23:"yii\db\Connection::open";i:3;d:1702123457.536275;i:4;a:1:{i:0;a:5:{s:4:"file";s:65:"C:\xampp\htdocs\visualight\backend\controllers\SiteController.php";s:4:"line";i:622;s:8:"function";s:3:"all";s:5:"class";s:12:"yii\db\Query";s:4:"type";